# Copie para .env e ajuste. Nunca commitar o .env real.

APP_NAME="Blacklist Monitor"
SECRET_KEY=troque-por-uma-string-aleatoria-longa
# Gere com: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=troque-por-uma-chave-fernet-base64-32-bytes

# Postgres em produção (ver docker-compose.yml). SQLite é o padrão para dev local.
DATABASE_URL=sqlite:///./blacklist_monitor.db
# DATABASE_URL=postgresql+psycopg2://blacklist:blacklist@postgres:5432/blacklist_monitor

# Resolver DNS dedicado (IPs separados por vírgula). Vazio = resolver do sistema.
# PRODUÇÃO: aponte para um Unbound local sem forwarding para resolvers públicos.
DNS_RESOLVERS=
SPAMHAUS_DQS_KEY=

DEFAULT_CHECK_INTERVAL_MINUTES=60
LISTED_IP_RECHECK_MINUTES=15
MAX_CIDR_EXPANSION=1024

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM=blacklist-monitor@localhost
PUSHOVER_APP_TOKEN=

CORS_ORIGINS=*
