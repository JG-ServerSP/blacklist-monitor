# Copy this to .env and adjust the values. Never commit the real .env file.

APP_NAME="Blacklist Monitor"
SECRET_KEY=change-me-to-a-long-random-string
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-to-a-base64-32-byte-fernet-key

# Postgres in production (see docker-compose.yml). SQLite is the default for local dev.
DATABASE_URL=sqlite:///./blacklist_monitor.db
# DATABASE_URL=postgresql+psycopg2://blacklist:blacklist@postgres:5432/blacklist_monitor

# First-boot admin account. If ADMIN_PASSWORD is empty, a random password is
# generated and printed once in the startup log — see the README.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# Dedicated DNS resolver (comma-separated IPs). Empty = use the system resolver.
# PRODUCTION: point this at a local Unbound instance with no forwarding to public resolvers.
DNS_RESOLVERS=
SPAMHAUS_DQS_KEY=

DEFAULT_CHECK_INTERVAL_MINUTES=60
LISTED_IP_RECHECK_MINUTES=15
MAX_CIDR_EXPANSION=1024

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM=blacklist-monitor@localhost
PUSHOVER_APP_TOKEN=

CORS_ORIGINS=*

# UI language: pt-BR, en, es, fr, or de.
LANGUAGE=en
# Log verbosity: off, error, info (default), or debug.
LOG_LEVEL=info
